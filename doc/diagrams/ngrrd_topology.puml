@startuml
!define RECTANGLE class

skinparam componentStyle rectangle
skinparam linetype ortho

title ngrrd — Visão de Contêiner (C4, objeto único NGRR)

actor "Aplicação cliente" as App

package "nishi-utils-oss" {
  component "Ngrrd\n(façade)" as Facade
  component "NgrrdYamlLoader\n+ Validator" as Loader
  component "Engine pura\n(CounterDeriver, PDP,\nRraConsolidator, BestFit)" as Engine
  component "NgrrdWriter\n(thread única)" as Writer
  component "NgrrdReader\n+ ViewExecutor" as Reader
  component "SeriesGeometry\n+ SeriesFileCodec" as Format
  component "NgrrdMetrics" as Metrics
}

interface "NgrrdStorage\n+ SeriesChannelProvider" as Storage
component "LocalDiskStorage\n(FileChannel in-place)" as Local
component "S3Storage\n(imagem + PUT)" as S3

database "Disco local\n(1 arquivo .ngrr/série)" as Disk
cloud "S3 / MinIO / Ceph\n(1 objeto .ngrr/série)" as Cloud

App --> Facade : write(ds, Sample)\ncheckpoint()\nread(preset|query)
Facade --> Loader : carrega + valida YAML
Loader --> Engine : monta definição imutável
Facade --> Writer : ingestão assíncrona
Facade --> Reader : leitura síncrona
Writer --> Engine : CounterDeriver → PDP → CDP (contínuo)
Writer --> Format : encode header/live-state + offsets do ring
Writer --> Storage : SeriesChannel.writeRegion / force
Writer --> Metrics : eventos quality
Reader --> Storage : SeriesChannel.openSeries + readRegion
Reader --> Format : decode header/live-state + ring
Storage <|-- Local
Storage <|-- S3
Local --> Disk
S3 --> Cloud

@enduml
