@startuml
title ngrrd — Fluxo de escrita (ingestão, objeto único NGRR)

actor Cliente
participant "Ngrrd.fromYaml" as Facade
participant "NgrrdWriter\n(worker thread)" as Writer
participant "CounterDeriver" as Deriv
participant "PDP em progresso\n(por coluna)" as PDP
participant "CDP em progresso\n(por archive×coluna)" as CDP
participant "SeriesFileCodec" as Codec
participant "SeriesChannel\n(disco in-place / S3 RMW)" as Channel

Cliente -> Facade : fromYaml(yaml, bindings, tags)
Facade -> Writer : abre série (openOrCreate)
Writer -> Channel : openSeries(seriesKey.ngrr)
alt arquivo ausente / geometria divergente
  Writer -> Codec : buildInitialImage (pré-aloca + rings NaN)
  Writer -> Channel : writeRegion(0, imagem) + force
else arquivo existente
  Writer -> Channel : readRegion(header + live-state)
  Writer -> Codec : decode → reidrata counterPrev + acumuladores
end

loop por sample
  Cliente -> Writer : write("in_octets", Sample(ts, v))
  Writer -> Deriv : derive(prev, curr) [atualiza counterPrev]
  Deriv --> Writer : derivedValue + flag (RESET/WRAP → métrica)
  alt slot base avançou
    Writer -> CDP : fold PDP completo (por archive)
    alt passo do archive fechou
      Writer -> CDP : finaliza CDP (xff)
      Writer -> Channel : writeRegion(cell) [avança ring, NaN-init]
    end
  end
  Writer -> PDP : add(derivedValue)
end

loop checkpoint() / flush()
  Writer -> CDP : emite CDP em progresso como parcial
  Writer -> Channel : writeRegion(cells parciais)
  Writer -> Channel : writeRegion(live-state) + force (fsync / PUT)
end

@enduml
