@startuml
title ngrrd — Fluxo de leitura (view, objeto único NGRR)

actor Cliente
participant "Ngrrd.read" as Facade
participant "ViewExecutor" as View
participant "NgrrdReader" as Reader
participant "BestFitSelector" as Selector
participant "SeriesFileCodec" as Codec
participant "SeriesChannel\n(snapshot de leitura)" as Channel

Cliente -> Facade : read("daily")
Facade -> View : run(preset, tags)
View -> View : resolve seriesKey via template
View -> Reader : new NgrrdReader(def, storage, seriesKey)
loop por DS no preset.series
  View -> Reader : read(dsName, ViewQuery)
  Reader -> Selector : pick(query, rras)
  Selector --> Reader : RraDef escolhida → (rra, cf) = archive
  Reader -> Channel : openSeries(seriesKey.ngrr)
  Reader -> Channel : readRegion(header)
  Reader -> Codec : decodeFixedHeader (valida geometria/hash)
  Reader -> Channel : readRegion(live-state) → curRow / anchor
  Reader -> Channel : readRegion(ring do archive)
  Reader -> Reader : reconstrói (ts,valor) por curRow/anchor/stepSec
  Reader -> Reader : recorta para window + downsample maxPoints
  Reader --> View : SeriesResult
end
View --> Cliente : Map<ds, SeriesResult>

note right of Reader
  Sem manifesto: a geometria e os
  ponteiros do ring são auto-descritos
  no próprio objeto da série.
end note

@enduml
