@startuml
title ngrrd — Fluxo de leitura (view)

actor Cliente
participant "Ngrrd.read" as Facade
participant "ViewExecutor" as View
participant "NgrrdReader" as Reader
participant "BestFitSelector" as Selector
participant "NgrrdStorage" as Storage
participant "ManifestCodec" as MCodec
participant "BlockCodec" as BCodec

Cliente -> Facade : read("daily")
Facade -> View : run(preset, tags)
View -> View : resolve seriesKey via template
View -> Reader : new NgrrdReader(def, storage, seriesKey)
loop por DS no preset.series
  View -> Reader : read(dsName, ViewQuery)
  Reader -> Selector : pick(query, rras)
  Selector --> Reader : RraDef escolhida
  Reader -> Storage : list(manifest/<seriesKey>/)
  Reader -> Storage : get(v{maxN}.yaml)
  Reader -> MCodec : readYaml(bytes)
  MCodec --> Reader : NgrrdManifest
  Reader -> Reader : filtra blocks por (rra, ds, cf)
  loop por bloco dentro da window
    Reader -> Storage : get(block.storageKey)
    Reader -> BCodec : decode(bytes)
    BCodec --> Reader : EncodedBlock (header + double[])
  end
  Reader -> Reader : recorta para window + downsample maxPoints
  Reader --> View : SeriesResult
end
View --> Cliente : Map<ds, SeriesResult>

@enduml
